{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "Node16",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node", "jest", "express"]
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "prisma.config.ts"]
}
